  pre_final_drive_db = 0 + (0 - 0) * core_auto_down + (-1.0 - 0) * core_auto_up;
  clip_drive_db = 0 + (0 - 0) * core_auto_down + (-0.6 - 0) * core_auto_up;
  overshoot_pct = 50 + (50 - 50) * core_auto_down + (75 - 50) * core_auto_up;
  lookahead_ms = lookahead_ms + (lookahead_ms - lookahead_ms) * core_auto_down;
  final_threshold_db = 0 + (0 - 0) * core_auto_down + (-0.6 - 0) * core_auto_up;
  final_threshold_makeup_pct = 0 + (0 - 0) * core_auto_down + (35 - 0) * core_auto_up;
);

core_mode == 1 ? (
  agc_amount_pct = 56 + (50 - 56) * core_auto_down + (75 - 56) * core_auto_up;
