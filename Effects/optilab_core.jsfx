);


input_section_in_l = spl0;
input_section_in_r = spl1;

l_in = input_section_in_l * input_gain;
  r_in = input_section_in_r * input_gain;

  subsonic_hpf ? (
    l = hp30_l.onepole_hp(l_in, hpf30_a);
    r = hp30_r.onepole_hp(r_in, hpf30_a);
  ) : (
    l = l_in;
    r = r_in;
  );

  phase_stages > 0 ? (
    l_rot = l;
    r_rot = r;
    phase_stages >= 1 ? ( l_rot = ap1_l.allpass1(l_rot, ap1_c); r_rot = ap1_r.allpass1(r_rot, ap1_c); );
    phase_stages >= 2 ? ( l_rot = ap2_l.allpass1(l_rot, ap2_c); r_rot = ap2_r.allpass1(r_rot, ap2_c); );
    phase_stages >= 3 ? ( l_rot = ap3_l.allpass1(l_rot, ap3_c); r_rot = ap3_r.allpass1(r_rot, ap3_c); );
    phase_stages >= 4 ? ( l_rot = ap4_l.allpass1(l_rot, ap4_c); r_rot = ap4_r.allpass1(r_rot, ap4_c); );
    phase_stages >= 5 ? ( l_rot = ap5_l.allpass1(l_rot, ap5_c); r_rot = ap5_r.allpass1(r_rot, ap5_c); );
    phase_stages >= 6 ? ( l_rot = ap6_l.allpass1(l_rot, ap6_c); r_rot = ap6_r.allpass1(r_rot, ap6_c); );
    phase_stages >= 7 ? ( l_rot = ap7_l.allpass1(l_rot, ap7_c); r_rot = ap7_r.allpass1(r_rot, ap7_c); );
    phase_stages >= 8 ? ( l_rot = ap8_l.allpass1(l_rot, ap8_c); r_rot = ap8_r.allpass1(r_rot, ap8_c); );
    phase_stages >= 9 ? ( l_rot = ap9_l.allpass1(l_rot, ap9_c); r_rot = ap9_r.allpass1(r_rot, ap9_c); );
    phase_stages >= 10 ? ( l_rot = ap10_l.allpass1(l_rot, ap10_c); r_rot = ap10_r.allpass1(r_rot, ap10_c); );
    phase_stages >= 11 ? ( l_rot = ap11_l.allpass1(l_rot, ap11_c); r_rot = ap11_r.allpass1(r_rot, ap11_c); );
    phase_stages >= 12 ? ( l_rot = ap12_l.allpass1(l_rot, ap12_c); r_rot = ap12_r.allpass1(r_rot, ap12_c); );
    l = l_rot;
    r = r_rot;
  );

input_section_proc_l = l;
input_section_proc_r = r;

agc_section_in_l = l;
agc_section_in_r = r;

first_hit_catch > 0 ? (
  startup_prev = startup_activity;
  startup_level = absmax2(l, r);
  quiet_factor = clamp((db2lin(-28) - startup_prev) / max(db2lin(-28), 0.000001), 0, 1);
  hit_factor = clamp((startup_level - db2lin(-18)) / max(db2lin(-6), 0.000001), 0, 1);
  first_hit_gain = db2lin(-2.5 * first_hit_catch * quiet_factor * hit_factor);
  l *= first_hit_gain;
  r *= first_hit_gain;
  startup_activity = max(startup_level, startup_activity * startup_activity_release);
) : (
  startup_activity = max(absmax2(l, r), startup_activity * startup_activity_release);
);

agc_l = l * agc_drive;
agc_r = r * agc_drive;

crossover_model == 1 ? (
  low_l = agc_lp_l.onepole_lp2(agc_l, agc_split_a);
  low_r = agc_lp_r.onepole_lp2(agc_r, agc_split_a);
) : (

  low_l = agc_lp_l.onepole_lp(agc_l, agc_split_a);
  low_r = agc_lp_r.onepole_lp(agc_r, agc_split_a);
);
high_l = agc_l - low_l;
high_r = agc_r - low_r;

low_det = absmax2(low_l, low_r);
high_det = absmax2(high_l, high_r);
full_det = absmax2(agc_l, agc_r);

low_env = agc_low_env.peak_env(low_det, agc_env_attack, agc_release);
high_env = agc_high_env.peak_env(high_det, agc_env_attack, agc_release);

gate_prog_env = max(full_det, gate_prog_env * gate_detector_release);
gate_open_now = full_det >= gate_lin ? 1 : 0;
gate_target = gate_prog_env < gate_lin ? 1 : 0;
gate_prev_state = gate_state;
gate_closed_memory = max(gate_closed_memory * gate_reopen_decay, gate_state);
gate_open_now > 0 ? (
  gate_state = gate_state * gate_open_coeff;
) : (
  gate_target > gate_state ? (
    gate_state = gate_target + gate_close_coeff * (gate_state - gate_target);
  ) : (
    gate_state = gate_target + gate_open_coeff * (gate_state - gate_target);
  );
);
gate_state = clamp(gate_state, 0, 1);

gate_effective = gate_state * (1 - gate_open_now);

gate_reopen_pulse = gate_open_now * clamp(max(gate_prev_state, gate_closed_memory) * gate_reopen_pulse_scale, 0, 1);
gate_reopen_env = max(gate_reopen_env * gate_reopen_decay, gate_reopen_pulse);
gate_open_now > 0 ? gate_closed_memory *= gate_reopen_decay;

gate_reopen_env > 0 ? (

  gate_mem_clear_coeff = 1 - gate_reopen_env * (1 - gate_reopen_env_release);
  low_env = agc_low_env.peak_env_set(low_det + gate_mem_clear_coeff * (low_env - low_det));
  high_env = agc_high_env.peak_env_set(high_det + gate_mem_clear_coeff * (high_env - high_det));
);

low_tgain = clamp(agc_target / max(low_env, 0.000001), agc_min_gain, agc_max_gain);
high_tgain = clamp(agc_target / max(high_env, 0.000001), agc_min_gain, agc_max_gain);

low_tgain = low_tgain * (1 - bass_coupling) + high_tgain * bass_coupling;

gate_effective > 0 ? (
  gated_low_tgain = min(low_tgain, agc_lgain);
  gated_high_tgain = min(high_tgain, agc_hgain);
  low_tgain = low_tgain * (1 - gate_effective) + gated_low_tgain * gate_effective;
  high_tgain = high_tgain * (1 - gate_effective) + gated_high_tgain * gate_effective;
);

agc_low_depth = clamp((1 - agc_lgain) / 0.75, 0, 1);
agc_high_depth = clamp((1 - agc_hgain) / 0.75, 0, 1);

pd_agc = pd_release * 0.15;
agc_low_rel = agc_release * (1 - pd_agc * agc_low_depth) + agc_release_slow * (pd_agc * agc_low_depth);
agc_high_rel = agc_release * (1 - pd_agc * agc_high_depth) + agc_release_slow * (pd_agc * agc_high_depth);

agc_low_rel = agc_low_rel * (1 - gate_effective) + gate_agc_freeze_release * gate_effective;
agc_high_rel = agc_high_rel * (1 - gate_effective) + gate_agc_freeze_release * gate_effective;

gate_reopen_rel_mix = gate_reopen_env * (0.35 + 0.45 * gate_reopen_strength);
agc_gate_reopen_rel_mix = gate_reopen_env * (0.06 + 0.16 * gate_reopen_strength);
agc_low_rel = agc_low_rel * (1 - agc_gate_reopen_rel_mix) + gate_reopen_release * agc_gate_reopen_rel_mix;
agc_high_rel = agc_high_rel * (1 - agc_gate_reopen_rel_mix) + gate_reopen_release * agc_gate_reopen_rel_mix;

low_tgain < agc_lgain ? agc_lgain = low_tgain + agc_gain_attack * (agc_lgain - low_tgain) : agc_lgain = low_tgain + agc_low_rel * (agc_lgain - low_tgain);
high_tgain < agc_hgain ? agc_hgain = high_tgain + agc_gain_attack * (agc_hgain - high_tgain) : agc_hgain = high_tgain + agc_high_rel * (agc_hgain - high_tgain);

gate_agc_drift_amt = (1 - gate_agc_drift_coeff) * gate_effective;
agc_lgain += gate_agc_drift_amt * (gate_agc_drift_target - agc_lgain);
agc_hgain += gate_agc_drift_amt * (gate_agc_drift_target - agc_hgain);

agc_drive_safe = max(agc_drive, 0.000001);
agc_low_raw_l = low_l / agc_drive_safe;
agc_low_raw_r = low_r / agc_drive_safe;
agc_high_raw_l = high_l / agc_drive_safe;
agc_high_raw_r = high_r / agc_drive_safe;

agc_low_proc_gain = agc_drive * agc_lgain;
agc_high_proc_gain = agc_drive * agc_hgain;
agc_low_authority = agc_low_proc_gain < 1 ? agc_down_mix : agc_mix;
agc_high_authority = agc_high_proc_gain < 1 ? agc_down_mix : agc_mix;
agc_low_eff_gain = 1 + (agc_low_proc_gain - 1) * agc_low_authority;
agc_high_eff_gain = 1 + (agc_high_proc_gain - 1) * agc_high_authority;

agc_out_l = agc_low_raw_l * agc_low_eff_gain + agc_high_raw_l * agc_high_eff_gain;
agc_out_r = agc_low_raw_r * agc_low_eff_gain + agc_high_raw_r * agc_high_eff_gain;

l = agc_out_l;
r = agc_out_r;

post_agc_smooth_drive_amt > 0.0000001 ? (
    l = post_agc_round_l.smooth_drive_rounder(l, post_agc_smooth_drive_amt) * post_agc_smooth_recovery_gain;
    r = post_agc_round_r.smooth_drive_rounder(r, post_agc_smooth_drive_amt) * post_agc_smooth_recovery_gain;
  );

agc_section_proc_l = l;
agc_section_proc_r = r;

mastering_lookahead_samps > 0 ? (
  master_side_det = absmax2(l, r);
  master_raw_det = absmax2(input_section_in_l, input_section_in_r);
  master_amp_det = master_side_det;

  master_startup_active = max(master_side_det, master_raw_det) > master_startup_active_thresh;
  master_startup_armed > 0 ? (
    master_startup_active ? (
      master_startup_age < master_startup_prime_window ? (
        i = 0;
        loop(master_buf_len,
          master_buf_l[i] = l;
          master_buf_r[i] = r;
          i += 1;
        );
        master_wrpos = 0;
        master_raw_env.peak_env_set(max(master_raw_det, 0.000001));
        master_amp_env.peak_env_set(max(master_amp_det, 0.000001));
        master_catch_env.peak_env_set(max(master_side_det, 0.000001));
        master_catch_gain = 1;
      );
      master_startup_armed = 0;
    ) : (
      master_startup_age += 1;
      master_startup_age >= master_startup_prime_window ? master_startup_armed = 0;
    );
  );

  master_raw_level = master_raw_env.peak_env(master_raw_det, master_env_attack, master_env_release);
  master_amp_level = master_amp_env.peak_env(master_amp_det, master_env_attack, master_env_release);
  master_net_makeup_db = lin2db(master_amp_level / max(master_raw_level, 0.000001));
  master_allow = clamp((master_net_makeup_db - 3.0) / 9.0, 0, 1);

  master_catch_thresh = db2lin(-6.2);
  master_catch_det = master_catch_env.peak_env(master_side_det, master_catch_attack, master_catch_release);
  master_target_gain = master_catch_det > master_catch_thresh ? master_catch_thresh / max(master_catch_det, 0.000001) : 1;
  master_target_gain = clamp(master_target_gain, db2lin(-3.6), 1);
  master_target_gain = 1 - master_allow * (1 - master_target_gain);
  master_target_gain < master_catch_gain ? (
    master_catch_gain = master_target_gain + master_catch_attack * (master_catch_gain - master_target_gain);
  ) : (
    master_catch_gain = master_target_gain + master_catch_release * (master_catch_gain - master_target_gain);
  );

  mrdpos = master_wrpos - mastering_lookahead_samps;
  mrdpos < 0 ? mrdpos += master_buf_len;
  md_l = master_buf_l[mrdpos];
  md_r = master_buf_r[mrdpos];
  master_buf_l[master_wrpos] = l;
  master_buf_r[master_wrpos] = r;
  master_wrpos += 1;
  master_wrpos >= master_buf_len ? master_wrpos = 0;

  l = md_l * master_catch_gain;
  r = md_r * master_catch_gain;
) : (
  master_catch_gain = 1;
  master_startup_armed = 1;
  master_startup_age = 0;
);

bass_section_in_l = l;
bass_section_in_r = r;
l = bass_peak_l.biquad_run(l);
r = bass_peak_r.biquad_run(r);

adaptive_bass_coupling > 0 ? (
  ab_low_l = adapt_bass_lp_l.onepole_lp2(l, adapt_bass_split_a);
  ab_low_r = adapt_bass_lp_r.onepole_lp2(r, adapt_bass_split_a);
  ab_high_l = l - ab_low_l;
  ab_high_r = r - ab_low_r;

  ab_bass_det = absmax2(ab_low_l, ab_low_r);
  ab_prog_det = max(absmax2(l, r), absmax2(ab_high_l, ab_high_r) * 1.20);

  ab_bass_env = adapt_bass_env.peak_env(ab_bass_det, adapt_bass_det_attack, adapt_bass_det_release);
  ab_prog_env = adapt_prog_env.peak_env(ab_prog_det, adapt_bass_det_attack, adapt_bass_det_release);
  ab_ratio = ab_bass_env / max(ab_prog_env, 0.000001);

  ab_thin = clamp((adapt_bass_target_low - ab_ratio) / max(adapt_bass_target_low - 0.105, 0.000001), 0, 1);
  ab_heavy = clamp((ab_ratio - adapt_bass_target_high) / max(0.82 - adapt_bass_target_high, 0.000001), 0, 1);
  ab_gain_target_db = adapt_bass_max_boost_db * ab_thin - adapt_bass_max_cut_db * ab_heavy;
  ab_gain_target = db2lin(ab_gain_target_db);

  adapt_bass_gain <= 0 ? adapt_bass_gain = 1;
  ab_gain_target < adapt_bass_gain ? (
    adapt_bass_gain = ab_gain_target + adapt_bass_gain_down * (adapt_bass_gain - ab_gain_target);
  ) : (
    adapt_bass_gain = ab_gain_target + adapt_bass_gain_up * (adapt_bass_gain - ab_gain_target);
  );

  l = ab_high_l + ab_low_l * adapt_bass_gain;
  r = ab_high_r + ab_low_r * adapt_bass_gain;
);

bass_clip > 0 ? (
  bc_low_l = bassclip_split_l.onepole_lp2(l, bass_clip_split_a);
  bc_low_r = bassclip_split_r.onepole_lp2(r, bass_clip_split_a);
  bc_high_l = l - bc_low_l;
  bc_high_r = r - bc_low_r;

  bc_drive_l = bassclip_hpf_l.onepole_hp(bc_low_l, bass_clip_subhp_a);
  bc_drive_r = bassclip_hpf_r.onepole_hp(bc_low_r, bass_clip_subhp_a);
  bc_sub_l = bc_low_l - bc_drive_l;
  bc_sub_r = bc_low_r - bc_drive_r;

  bc_clip_l = bassclip_pre_l.bass_clip_active(bc_drive_l, bass_clip_pre_th, bass_clip_pre_amt, 0.42, bass_clip_pre_drive, 0.22, bass_clip_pre_res_a);
  bc_clip_r = bassclip_pre_r.bass_clip_active(bc_drive_r, bass_clip_pre_th, bass_clip_pre_amt, 0.42, bass_clip_pre_drive, 0.22, bass_clip_pre_res_a);

  l = bc_high_l + bc_sub_l + bc_clip_l * bass_clip_makeup;
  r = bc_high_r + bc_sub_r + bc_clip_r * bass_clip_makeup;
);

bass_section_proc_l = l;
bass_section_proc_r = r;

xt2_section_in_l = l;
xt2_section_in_r = r;

l *= density_audio_gain;
r *= density_audio_gain;

crossover_model == 3 ? (

  lp1_l = lr4b1b_l.biquad_run(lr4b1a_l.biquad_run(l));
  lp2_l = lr4b2b_l.biquad_run(lr4b2a_l.biquad_run(l));
  lp3_l = lr4b3b_l.biquad_run(lr4b3a_l.biquad_run(l));
  lp4_l = lr4b4b_l.biquad_run(lr4b4a_l.biquad_run(l));
  lp5_l = lr4b5b_l.biquad_run(lr4b5a_l.biquad_run(l));
  b1_l = lp1_l;
  b2_l = lp2_l - lp1_l;
  b3_l = lp3_l - lp2_l;
  b4_l = lp4_l - lp3_l;
  b5_l = lp5_l - lp4_l;
  b6_l = l - lp5_l;

  lp1_r = lr4b1b_r.biquad_run(lr4b1a_r.biquad_run(r));
  lp2_r = lr4b2b_r.biquad_run(lr4b2a_r.biquad_run(r));
  lp3_r = lr4b3b_r.biquad_run(lr4b3a_r.biquad_run(r));
  lp4_r = lr4b4b_r.biquad_run(lr4b4a_r.biquad_run(r));
  lp5_r = lr4b5b_r.biquad_run(lr4b5a_r.biquad_run(r));
  b1_r = lp1_r;
  b2_r = lp2_r - lp1_r;
  b3_r = lp3_r - lp2_r;
  b4_r = lp4_r - lp3_r;
  b5_r = lp5_r - lp4_r;
  b6_r = r - lp5_r;
) : crossover_model == 2 ? (
  lp1_l = xb1_l.onepole_lp2(l, x1_a);
  lp2_l = xb2_l.onepole_lp2(l, x2_a);
  lp3_l = xb3_l.onepole_lp2(l, x3_a);
  lp4_l = xb4_l.onepole_lp2(l, x4_a);
  lp5_l = xb5_l.onepole_lp2(l, x5_a);
  b1_l = lp1_l;
  b2_l = lp2_l - lp1_l;
  b3_l = lp3_l - lp2_l;
  b4_l = lp4_l - lp3_l;
  b5_l = lp5_l - lp4_l;
  b6_l = l - lp5_l;

  lp1_r = xb1_r.onepole_lp2(r, x1_a);
  lp2_r = xb2_r.onepole_lp2(r, x2_a);
  lp3_r = xb3_r.onepole_lp2(r, x3_a);
  lp4_r = xb4_r.onepole_lp2(r, x4_a);
  lp5_r = xb5_r.onepole_lp2(r, x5_a);
  b1_r = lp1_r;
  b2_r = lp2_r - lp1_r;
  b3_r = lp3_r - lp2_r;
  b4_r = lp4_r - lp3_r;
  b5_r = lp5_r - lp4_r;
  b6_r = r - lp5_r;
) : crossover_model == 1 ? (

  b1_l = xb1_l.onepole_lp2(l, x1_a);
  rem_l = l - b1_l;
  b2_l = xb2_l.onepole_lp2(rem_l, x2_a);
  rem_l -= b2_l;
  b3_l = xb3_l.onepole_lp2(rem_l, x3_a);
  rem_l -= b3_l;
  b4_l = xb4_l.onepole_lp2(rem_l, x4_a);
  rem_l -= b4_l;
  b5_l = xb5_l.onepole_lp2(rem_l, x5_a);
  b6_l = rem_l - b5_l;

  b1_r = xb1_r.onepole_lp2(r, x1_a);
  rem_r = r - b1_r;
  b2_r = xb2_r.onepole_lp2(rem_r, x2_a);
  rem_r -= b2_r;
  b3_r = xb3_r.onepole_lp2(rem_r, x3_a);
  rem_r -= b3_r;
  b4_r = xb4_r.onepole_lp2(rem_r, x4_a);
  rem_r -= b4_r;
  b5_r = xb5_r.onepole_lp2(rem_r, x5_a);
  b6_r = rem_r - b5_r;
) : (
  b1_l = xb1_l.onepole_lp(l, x1_a);
  rem_l = l - b1_l;
  b2_l = xb2_l.onepole_lp(rem_l, x2_a);
  rem_l -= b2_l;
  b3_l = xb3_l.onepole_lp(rem_l, x3_a);
  rem_l -= b3_l;
  b4_l = xb4_l.onepole_lp(rem_l, x4_a);
  rem_l -= b4_l;
  b5_l = xb5_l.onepole_lp(rem_l, x5_a);
  b6_l = rem_l - b5_l;

  b1_r = xb1_r.onepole_lp(r, x1_a);
  rem_r = r - b1_r;
  b2_r = xb2_r.onepole_lp(rem_r, x2_a);
  rem_r -= b2_r;
  b3_r = xb3_r.onepole_lp(rem_r, x3_a);
  rem_r -= b3_r;
  b4_r = xb4_r.onepole_lp(rem_r, x4_a);
  rem_r -= b4_r;
  b5_r = xb5_r.onepole_lp(rem_r, x5_a);
  b6_r = rem_r - b5_r;
);

adaptive_top_coupling > 0 ? (
  at_b4_det = absmax2(b4_l, b4_r);
  at_b5_det = absmax2(b5_l, b5_r);
  at_b6_det = absmax2(b6_l, b6_r);

  at_air_l = adapt_top_air_hp_l.onepole_hp(l, adapt_top_air_hp_a);
  at_air_r = adapt_top_air_hp_r.onepole_hp(r, adapt_top_air_hp_a);
  at_air_det = absmax2(at_air_l, at_air_r);

  at_edge_det = at_b4_det * 0.30 + at_b5_det * 0.85 + at_b6_det * 0.18;
  at_prog_det = max(absmax2(l, r), max(at_edge_det, at_air_det) * 1.08);

  at_edge_env = adapt_top_edge_env.peak_env(at_edge_det, adapt_top_det_attack, adapt_top_det_release);
  at_edge_prog_env = adapt_top_edge_prog_env.peak_env(at_prog_det, adapt_top_det_attack, adapt_top_det_release);
  at_edge_ratio = at_edge_env / max(at_edge_prog_env, 0.000001);

  at_air_env = adapt_top_air_env.peak_env(at_air_det, adapt_top_det_attack, adapt_top_det_release);
  at_air_prog_env = adapt_top_air_prog_env.peak_env(at_prog_det, adapt_top_det_attack, adapt_top_det_release);
  at_air_ratio = at_air_env / max(at_air_prog_env, 0.000001);

  at_edge_dull = clamp((adapt_top_edge_target_low - at_edge_ratio) / max(adapt_top_edge_target_low - 0.060, 0.000001), 0, 1);
  at_edge_bright = clamp((at_edge_ratio - adapt_top_edge_target_high) / max(0.78 - adapt_top_edge_target_high, 0.000001), 0, 1);
  at_presence_gain_target_db = adapt_top_presence_max_boost_db * at_edge_dull - adapt_top_presence_max_cut_db * at_edge_bright;

  at_air_dull = clamp((adapt_top_air_target_low - at_air_ratio) / max(adapt_top_air_target_low - 0.006, 0.000001), 0, 1);
  at_air_bright = clamp((at_air_ratio - adapt_top_air_target_high) / max(0.38 - adapt_top_air_target_high, 0.000001), 0, 1);
  at_air_gain_target_db = adapt_top_air_max_boost_db * at_air_dull - adapt_top_air_max_cut_db * at_air_bright;

  at_edge_guard = clamp((at_edge_ratio - 0.46) / 0.34, 0, 1);
  at_air_positive_db = max(at_air_gain_target_db, 0);
  at_air_gain_target_db -= at_air_positive_db * (0.55 * at_edge_guard);

  at_presence_gain_target = db2lin(at_presence_gain_target_db);
  at_air_gain_target = db2lin(at_air_gain_target_db);

  adapt_top_presence_gain <= 0 ? adapt_top_presence_gain = 1;
  at_presence_gain_target < adapt_top_presence_gain ? (
    adapt_top_presence_gain = at_presence_gain_target + adapt_top_gain_down * (adapt_top_presence_gain - at_presence_gain_target);
  ) : (
    adapt_top_presence_gain = at_presence_gain_target + adapt_top_gain_up * (adapt_top_presence_gain - at_presence_gain_target);
  );

  adapt_top_air_gain <= 0 ? adapt_top_air_gain = 1;
  at_air_gain_target < adapt_top_air_gain ? (
    adapt_top_air_gain = at_air_gain_target + adapt_top_gain_down * (adapt_top_air_gain - at_air_gain_target);
  ) : (
    adapt_top_air_gain = at_air_gain_target + adapt_top_gain_up * (adapt_top_air_gain - at_air_gain_target);
  );

  top_presence_adapt_gain = adapt_top_presence_gain;
  top_air_adapt_gain = adapt_top_air_gain;
) : (
  adapt_top_presence_gain = 1;
  adapt_top_air_gain = 1;
  top_presence_adapt_gain = 1;
  top_air_adapt_gain = 1;
);

b4_l *= presence_gain * top_presence_adapt_gain; b4_r *= presence_gain * top_presence_adapt_gain;
b5_l *= presence_gain * top_presence_adapt_gain; b5_r *= presence_gain * top_presence_adapt_gain;
b6_l *= brilliance_gain * top_air_adapt_gain; b6_r *= brilliance_gain * top_air_adapt_gain;

b1_det = absmax2(b1_l, b1_r) * density_detector_gain * db2lin(-bass_eq_work_db * 0.55 * bass_sc_relief - 1.00 * low_bass_floor);
b2_det = absmax2(b2_l, b2_r) * density_detector_gain * db2lin(-bass_eq_work_db * 0.35 * bass_sc_relief - 0.45 * low_bass_floor);

gate_xt2_strength = gate_effective * 0.78;
low_band_release_gated = low_band_release * (1 - gate_xt2_strength) + gate_xt2_freeze_release * gate_xt2_strength;
low_band_release_slow_gated = low_band_release_slow * (1 - gate_xt2_strength) + gate_xt2_freeze_release * gate_xt2_strength;
band_release_gated = band_release * (1 - gate_xt2_strength) + gate_xt2_freeze_release * gate_xt2_strength;
band_release_slow_gated = band_release_slow * (1 - gate_xt2_strength) + gate_xt2_freeze_release * gate_xt2_strength;
low_band_release_gated = low_band_release_gated * (1 - gate_reopen_rel_mix) + gate_reopen_release * gate_reopen_rel_mix;
low_band_release_slow_gated = low_band_release_slow_gated * (1 - gate_reopen_rel_mix) + gate_reopen_release * gate_reopen_rel_mix;
band_release_gated = band_release_gated * (1 - gate_reopen_rel_mix) + gate_reopen_release * gate_reopen_rel_mix;
band_release_slow_gated = band_release_slow_gated * (1 - gate_reopen_rel_mix) + gate_reopen_release * gate_reopen_rel_mix;
g1 = lim1.band_limit_gain_pd(b1_det, b1_thresh, band_attack, low_band_release_gated, low_band_release_slow_gated, pd_release);
g2 = lim2.band_limit_gain_pd(b2_det, b2_thresh, band_attack, low_band_release_gated, low_band_release_slow_gated, pd_release);

g3 = lim3.band_limit_gain_pd_soft(absmax2(b3_l, b3_r) * density_detector_gain, b3_thresh, upper_mid_band_attack, band_release_gated, band_release_slow_gated, pd_release, 4.2, 0.30, 0.14);
g4 = lim4.band_limit_gain_pd_soft(absmax2(b4_l, b4_r) * density_detector_gain, b4_thresh, upper_band_attack, band_release_gated, band_release_slow_gated, pd_release, 3.1, 0.42, 0.16);
g5 = lim5.band_limit_gain_pd_soft(absmax2(b5_l, b5_r) * density_detector_gain, b5_thresh, upper_band_attack, band_release_gated, band_release_slow_gated, pd_release, 2.6, 0.55, 0.18);
g6 = lim6.band_limit_gain_pd_soft(absmax2(b6_l, b6_r) * density_detector_gain, b6_thresh, upper_band_attack, band_release_gated, band_release_slow_gated, pd_release, 2.4, 0.65, 0.20);

g1 = 1 - xt2_mix * (1 - g1);
g2 = 1 - xt2_mix * (1 - g2);
g3 = 1 - xt2_mix * (1 - g3);
g4 = 1 - xt2_mix * (1 - g4);
g5 = 1 - xt2_mix * (1 - g5);
g6 = 1 - xt2_mix * (1 - g6);

low_shared_gain = sqrt(max(g1 * g2, 0.000001));
g1 = g1 * (1 - low_coherence) + low_shared_gain * low_coherence;
g2 = g2 * (1 - low_coherence) + low_shared_gain * low_coherence;

g6 = g5;

mb_clip_mix > 0 ? (
  dc3_amt = dc_cancel * 0.35;
  dc4_amt = dc_cancel * 0.55;
  dc5_amt = dc_cancel * 0.78;
  dc6_amt = dc_cancel * 0.92;

  b3_l = mb_clip3_l.mb_soft_clip_dc(b3_l, mb_work_ref * 0.56, mb_clip_mix * 0.55, 0.42, dc3_amt, dist_cancel_a);
  b3_r = mb_clip3_r.mb_soft_clip_dc(b3_r, mb_work_ref * 0.56, mb_clip_mix * 0.55, 0.42, dc3_amt, dist_cancel_a);
  b4_l = mb_clip4_l.mb_soft_clip_dc(b4_l, mb_work_ref * 0.48, mb_clip_mix * 0.75, 0.36, dc4_amt, dist_cancel_a);
  b4_r = mb_clip4_r.mb_soft_clip_dc(b4_r, mb_work_ref * 0.48, mb_clip_mix * 0.75, 0.36, dc4_amt, dist_cancel_a);
  b5_l = mb_clip5_l.mb_soft_clip_dc(b5_l, mb_work_ref * 0.40, mb_clip_mix, 0.30, dc5_amt, dist_cancel_a);
  b5_r = mb_clip5_r.mb_soft_clip_dc(b5_r, mb_work_ref * 0.40, mb_clip_mix, 0.30, dc5_amt, dist_cancel_a);
  b6_l = mb_clip6_l.mb_soft_clip_dc(b6_l, mb_work_ref * 0.32, mb_clip_mix, 0.24, dc6_amt, dist_cancel_a);
  b6_r = mb_clip6_r.mb_soft_clip_dc(b6_r, mb_work_ref * 0.32, mb_clip_mix, 0.24, dc6_amt, dist_cancel_a);
);

p1_l = b1_l*g1; p1_r = b1_r*g1;
p2_l = b2_l*g2; p2_r = b2_r*g2;
p3_l = b3_l*g3; p3_r = b3_r*g3;
p4_l = b4_l*g4; p4_r = b4_r*g4;
p5_l = b5_l*g5; p5_r = b5_r*g5;
p6_l = b6_l*g6; p6_r = b6_r*g6;

effective_snubber_lookahead > 0 ? (
  srdpos = snub_wrpos - effective_snubber_lookahead;
  srdpos < 0 ? srdpos += snub_buf_len;

