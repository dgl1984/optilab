  clip_ceiling_db = 0;
  top_filter_mode = 0;
  output_trim_db = 0;
  smooth_drive_rounder_pct = 50;
);

processor_mode = core_mode == 2 ? 1 : 0;

core_last_mode = core_mode;
core_initial_apply = 0;

input_trim_db = clamp(input_drive_db, -12, 18);

core_auto_down = clamp((45 - auto_adapt_pct) / 45, 0, 1);
core_auto_up = clamp((auto_adapt_pct - 55) / 45, 0, 1);

core_mode == 0 ? (
  agc_amount_pct = 65 + (52 - 65) * core_auto_down + (85 - 65) * core_auto_up;
  agc_drive_db = 0.5 + (-0.8 - 0.5) * core_auto_down + (2.0 - 0.5) * core_auto_up;
  release_time = 7 + (8 - 7) * core_auto_down + (5.6 - 7) * core_auto_up;
  pd_release_pct = 70 + (65 - 70) * core_auto_down + (88 - 70) * core_auto_up;
  gate_threshold_db = -30 + (-30 + 30) * core_auto_down + (-34 + 30) * core_auto_up;
  gate_reopen_speed_ms = 40 + (55 - 40) * core_auto_down + (28 - 40) * core_auto_up;
  gate_reopen_strength_pct = 65 + (55 - 65) * core_auto_down + (88 - 65) * core_auto_up;
  first_hit_catch_pct = 35 + (35 - 35) * core_auto_down + (70 - 35) * core_auto_up;
  post_agc_smooth_drive_pct = 25 + (14 - 25) * core_auto_down + (25 - 25) * core_auto_up;
  bass_coupling_pct = 70 + (60 - 70) * core_auto_down + (70 - 70) * core_auto_up;
  bass_sc_relief_pct = 35 + (35 - 35) * core_auto_down + (58 - 35) * core_auto_up;
  low_coherence_pct = 65 + (58 - 65) * core_auto_down + (65 - 65) * core_auto_up;
  low_release_stab_pct = 70 + (65 - 70) * core_auto_down + (82 - 70) * core_auto_up;
  adaptive_bass_coupling_pct = 12 + (12 - 12) * core_auto_down + (24 - 12) * core_auto_up;
  density_db = 1 + (0.2 - 1) * core_auto_down + (1.6 - 1) * core_auto_up;
  adaptive_top_coupling_pct = 35 + (35 - 35) * core_auto_down + (58 - 35) * core_auto_up;
