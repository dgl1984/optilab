);

p1_l = dp1_l; p1_r = dp1_r;
p2_l = dp2_l; p2_r = dp2_r;
p3_l = dp3_l; p3_r = dp3_r;
p4_l = dp4_l; p4_r = dp4_r;
p5_l = dp5_l; p5_r = dp5_r;
p6_l = dp6_l; p6_r = dp6_r;

sum_l = p1_l + p2_l + p3_l + p4_l + p5_l + p6_l;
sum_r = p1_r + p2_r + p3_r + p4_r + p5_r + p6_r;
recomb_l = soft_clip_knee(sum_l, recomb_clip_thresh, recomb_clip_knee);
recomb_r = soft_clip_knee(sum_r, recomb_clip_thresh, recomb_clip_knee);
l = sum_l + recomb_control * (recomb_l - sum_l);
r = sum_r + recomb_control * (recomb_r - sum_r);

transition_fill > 0 ? (
  l = transition_peak_l.biquad_run(l);
  r = transition_peak_r.biquad_run(r);
);

low_bass_floor > 0 ? (
  l = low_floor_l.biquad_run(l);
  r = low_floor_r.biquad_run(r);
);

post_xt2_smooth_drive_amt > 0.0000001 ? (
    l = post_xt2_round_l.smooth_drive_rounder(l, post_xt2_smooth_drive_amt) * post_xt2_smooth_recovery_gain;
    r = post_xt2_round_r.smooth_drive_rounder(r, post_xt2_smooth_drive_amt) * post_xt2_smooth_recovery_gain;
  );

xt2_section_proc_l = l;
xt2_section_proc_r = r;

stereo_section_in_l = l;
stereo_section_in_r = r;


mid = (l + r) * 0.5;
side = (l - r) * 0.5;
side *= side_scale;

stereo_section_active ? (
  stereo_mode == 1 ? (
    side = soft_clip_knee(side, max(0.05, abs(mid) * 0.90 + 0.08), 0.30);
  );
);

l = mid + side;
r = mid - side;

stereo_section_proc_l = l;
stereo_section_proc_r = r;

final_section_in_l = l;
final_section_in_r = r;

l *= pre_final_drive_gain;
r *= pre_final_drive_gain;

final_threshold_drive_s <= 0 ? final_threshold_drive_s = final_threshold_drive_target;
final_threshold_drive_s = final_threshold_drive_target + final_threshold_smooth * (final_threshold_drive_s - final_threshold_drive_target);
final_threshold_drive = final_threshold_drive_s;

final_threshold_makeup_cancel = final_threshold_drive > 1 ? exp(-log(final_threshold_drive) * (1 - final_threshold_makeup)) : 1;


l *= final_threshold_drive;
r *= final_threshold_drive;

clip_full_det = absmax2(l, r);
clip_full_env = final_full_env.peak_env(clip_full_det, clip_attack, clip_release);
level_factor = clamp((clip_full_env - ceiling * 0.55) / max(ceiling * 0.35, 0.000001), 0, 1);
protect_db = peak_only_final_limiter ? 0 : -2.0 * clip_restraint * level_factor;
dynamic_clip_gain = db2lin(protect_db);
final_drive_gain = peak_only_final_limiter ? 1 : clip_drive_full * dynamic_clip_gain;

l *= final_drive_gain;
r *= final_drive_gain;

pre_det = absmax2(l, r);
pre_tgain = preclip.linked_limiter_gain(pre_det, prelimit_thresh, clip_attack, clip_release);
pre_tgain = 1 - prelimit_mix * (1 - pre_tgain);
l *= pre_tgain;
r *= pre_tgain;

clip_in_l = l;
clip_in_r = r;
peak_only_final_limiter ? (
  clip_l = clip_in_l;
  clip_r = clip_in_r;
) : (
  clip_l = soft_clip_knee(clip_in_l, clip_stage1, clip_knee1);
  clip_r = soft_clip_knee(clip_in_r, clip_stage1, clip_knee1);
  clip_l = soft_clip_knee(clip_l, clip_stage2, clip_knee2);
  clip_r = soft_clip_knee(clip_r, clip_stage2, clip_knee2);
);

dist_l = clip_l - clip_in_l;
dist_r = clip_r - clip_in_r;
dist_low_l = dist_lpf_l.onepole_lp(dist_l, dist_cancel_a);
dist_low_r = dist_lpf_r.onepole_lp(dist_r, dist_cancel_a);

l = clip_l - dist_low_l * dc_cancel * 0.45;
r = clip_r - dist_low_r * dc_cancel * 0.45;

top_filter_mode == 1 ? (
  l = lpf15_1_l.biquad_run(l);
  r = lpf15_1_r.biquad_run(r);
) : top_filter_mode >= 2 ? (
  l = lpf15_2_l.biquad_run(lpf15_1_l.biquad_run(l));
  r = lpf15_2_r.biquad_run(lpf15_1_r.biquad_run(r));
);


l *= final_threshold_makeup_cancel;
r *= final_threshold_makeup_cancel;

l *= output_gain;
r *= output_gain;

smooth_drive_rounder_amt > 0.0000001 ? (
  l = final_round_l.smooth_drive_rounder(l, smooth_drive_rounder_amt);
  r = final_round_r.smooth_drive_rounder(r, smooth_drive_rounder_amt);
);

fcs_thresh = fcs_thresh_setting;
ov_l = l - hard_limit(l, fcs_thresh);
ov_r = r - hard_limit(r, fcs_thresh);
ov_l = fcs_res_l.onepole_lp(ov_l, fcs_residue_a);
ov_r = fcs_res_r.onepole_lp(ov_r, fcs_residue_a);

effective_final_lookahead > 0 ? (
  rdpos = fcs_wrpos - effective_final_lookahead;
  rdpos < 0 ? rdpos += fcs_buf_len;

  dl = fcs_buf_l[rdpos];
  dr = fcs_buf_r[rdpos];
  dol = fcs_buf_ol[rdpos];
  dor = fcs_buf_or[rdpos];

  fcs_buf_l[fcs_wrpos] = l;
  fcs_buf_r[fcs_wrpos] = r;
  fcs_buf_ol[fcs_wrpos] = ov_l;
  fcs_buf_or[fcs_wrpos] = ov_r;

  fcs_wrpos += 1;
  fcs_wrpos >= fcs_buf_len ? fcs_wrpos = 0;

  l = dl - dol * overshoot_amt;
  r = dr - dor * overshoot_amt;
) : (
  l = l - ov_l * overshoot_amt;
  r = r - ov_r * overshoot_amt;
);

final_section_proc_l = hard_limit(l, ceiling);
final_section_proc_r = hard_limit(r, ceiling);

normal_out_l = final_section_proc_l;
normal_out_r = final_section_proc_r;

spl0 = normal_out_l;
spl1 = normal_out_r;
