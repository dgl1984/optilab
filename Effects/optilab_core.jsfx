  us_mix5 = us_amt * us_ngate5 * 0.92;
  us_mix6 = us_amt * us_ngate6 * 0.62;

  dp4_l = pure_peak_round(dp4_l, us_th4, us_mix4, 0.42 + 0.10 * us_amt);
  dp4_r = pure_peak_round(dp4_r, us_th4, us_mix4, 0.42 + 0.10 * us_amt);
  dp5_l = pure_peak_round(dp5_l, us_th5, us_mix5, 0.48 + 0.14 * us_amt);
