  us_ngate5 = ub_gate5.peak_env(us_ngate5, upper_snub_gain_attack, upper_snub_gain_release);
  us_ngate6 = ub_gate6.peak_env(us_ngate6, upper_snub_gain_attack, upper_snub_gain_release);

  us_floor4 = ceiling * 0.105;
  us_floor5 = ceiling * 0.080;
  us_floor6 = ceiling * 0.060;

  us_cap4 = ceiling * (0.46 - 0.07 * us_amt);
  us_cap5 = ceiling * (0.36 - 0.075 * us_amt);
  us_cap6 = ceiling * (0.30 - 0.060 * us_amt);

