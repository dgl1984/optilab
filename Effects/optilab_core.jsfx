peak_only_final_limiter = (clipper_style == 0 && pre_limiter_pct >= 99 && clip_restraint_pct >= 99 && smooth_drive_rounder_pct <= 0.001 && post_agc_smooth_drive_pct <= 0.001 && post_xt2_smooth_drive_pct <= 0.001 && abs(pre_final_drive_db) <= 0.001 && top_filter_mode == 0 && output_trim_db == 0 && final_threshold_db >= -0.001 && final_threshold_db <= 0.001);
