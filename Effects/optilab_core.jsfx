  dp2_l = snub_p2_l[srdpos]; dp2_r = snub_p2_r[srdpos];
  dp3_l = snub_p3_l[srdpos]; dp3_r = snub_p3_r[srdpos];
  dp4_l = snub_p4_l[srdpos]; dp4_r = snub_p4_r[srdpos];
  dp5_l = snub_p5_l[srdpos]; dp5_r = snub_p5_r[srdpos];
  dp6_l = snub_p6_l[srdpos]; dp6_r = snub_p6_r[srdpos];

  snub_p1_l[snub_wrpos] = p1_l; snub_p1_r[snub_wrpos] = p1_r;
  snub_p2_l[snub_wrpos] = p2_l; snub_p2_r[snub_wrpos] = p2_r;
  snub_p3_l[snub_wrpos] = p3_l; snub_p3_r[snub_wrpos] = p3_r;
  snub_p4_l[snub_wrpos] = p4_l; snub_p4_r[snub_wrpos] = p4_r;
  snub_p5_l[snub_wrpos] = p5_l; snub_p5_r[snub_wrpos] = p5_r;
  snub_p6_l[snub_wrpos] = p6_l; snub_p6_r[snub_wrpos] = p6_r;

  snub_wrpos += 1;
  snub_wrpos >= snub_buf_len ? snub_wrpos = 0;
) : (
  dp1_l = p1_l; dp1_r = p1_r;
  dp2_l = p2_l; dp2_r = p2_r;
  dp3_l = p3_l; dp3_r = p3_r;
  dp4_l = p4_l; dp4_r = p4_r;
  dp5_l = p5_l; dp5_r = p5_r;
  dp6_l = p6_l; dp6_r = p6_r;
);

upper_snubber > 0 ? (
  us_amt = upper_snubber;

  us_lvl4 = absmax2(p4_l, p4_r);
  us_lvl5 = absmax2(p5_l, p5_r);
  us_lvl6 = absmax2(p6_l, p6_r);

  us_fast4 = ub_fast4.onepole_lp(us_lvl4, upper_snub_fast_a);
  us_fast5 = ub_fast5.onepole_lp(us_lvl5, upper_snub_fast_a);
  us_fast6 = ub_fast6.onepole_lp(us_lvl6, upper_snub_fast_a);
  us_slow4 = ub_slow4.onepole_lp(us_lvl4, upper_snub_slow_a);
  us_slow5 = ub_slow5.onepole_lp(us_lvl5, upper_snub_slow_a);
  us_slow6 = ub_slow6.onepole_lp(us_lvl6, upper_snub_slow_a);

  us_onset4 = clamp((us_fast4 - us_slow4 * 1.22) / max(us_slow4 * 0.80 + 0.000001, 0.000001), 0, 1);
  us_onset5 = clamp((us_fast5 - us_slow5 * 1.18) / max(us_slow5 * 0.72 + 0.000001, 0.000001), 0, 1);
  us_onset6 = clamp((us_fast6 - us_slow6 * 1.15) / max(us_slow6 * 0.66 + 0.000001, 0.000001), 0, 1);

  us_spike4 = clamp((us_lvl4 - us_slow4 * 1.20) / max(us_slow4 * 1.20 + 0.000001, 0.000001), 0, 1);
  us_spike5 = clamp((us_lvl5 - us_slow5 * 1.16) / max(us_slow5 * 1.05 + 0.000001, 0.000001), 0, 1);
  us_spike6 = clamp((us_lvl6 - us_slow6 * 1.12) / max(us_slow6 * 0.95 + 0.000001, 0.000001), 0, 1);

  us_d4 = max(abs(p4_l - us_prev4_l), abs(p4_r - us_prev4_r));
  us_d5 = max(abs(p5_l - us_prev5_l), abs(p5_r - us_prev5_r));
  us_d6 = max(abs(p6_l - us_prev6_l), abs(p6_r - us_prev6_r));

  us_c4 = max(abs(p4_l - 2*us_prev4_l + us_prev24_l), abs(p4_r - 2*us_prev4_r + us_prev24_r));
  us_c5 = max(abs(p5_l - 2*us_prev5_l + us_prev25_l), abs(p5_r - 2*us_prev5_r + us_prev25_r));
  us_c6 = max(abs(p6_l - 2*us_prev6_l + us_prev26_l), abs(p6_r - 2*us_prev6_r + us_prev26_r));

  us_prev24_l = us_prev4_l; us_prev24_r = us_prev4_r;
  us_prev25_l = us_prev5_l; us_prev25_r = us_prev5_r;
  us_prev26_l = us_prev6_l; us_prev26_r = us_prev6_r;
  us_prev4_l = p4_l; us_prev4_r = p4_r;
  us_prev5_l = p5_l; us_prev5_r = p5_r;
  us_prev6_l = p6_l; us_prev6_r = p6_r;

  us_dslow4 = ub_dslow4.onepole_lp(us_d4, upper_snub_delta_a);
  us_dslow5 = ub_dslow5.onepole_lp(us_d5, upper_snub_delta_a);
  us_dslow6 = ub_dslow6.onepole_lp(us_d6, upper_snub_delta_a);
  us_cslow4 = ub_cslow4.onepole_lp(us_c4, upper_snub_curve_a);
  us_cslow5 = ub_cslow5.onepole_lp(us_c5, upper_snub_curve_a);
  us_cslow6 = ub_cslow6.onepole_lp(us_c6, upper_snub_curve_a);

  us_dgate4 = clamp((us_d4 - us_dslow4 * 1.75) / max(us_dslow4 * 2.60 + 0.000001, 0.000001), 0, 1);
  us_dgate5 = clamp((us_d5 - us_dslow5 * 1.70) / max(us_dslow5 * 2.35 + 0.000001, 0.000001), 0, 1);
  us_dgate6 = clamp((us_d6 - us_dslow6 * 1.65) / max(us_dslow6 * 2.20 + 0.000001, 0.000001), 0, 1);
  us_cgate4 = clamp((us_c4 - us_cslow4 * 1.85) / max(us_cslow4 * 2.75 + 0.000001, 0.000001), 0, 1);
  us_cgate5 = clamp((us_c5 - us_cslow5 * 1.78) / max(us_cslow5 * 2.45 + 0.000001, 0.000001), 0, 1);
  us_cgate6 = clamp((us_c6 - us_cslow6 * 1.72) / max(us_cslow6 * 2.30 + 0.000001, 0.000001), 0, 1);

  us_shape4 = max(us_dgate4, us_cgate4);
