// @description OptiLab Core
// @version 1.0
// @author LanesAudio
// @about
//   OptiLab Core is a JSFX audio processor for REAPER.
//   It brings leveling, density, tone control, saturation, and limiting together.
// @changelog
//   v1.0
//   - Initial release
// @link
//   Donations: https://paypal.me/dgl1984
//   Website/Contact: info@lanesaudio.com
// @provides
//   optilab_core.jsfx

desc:OptiLab Core v1.0 (LanesAudio)

slider1:core_mode=0<0,2,1{Podcast Leveler,Stream Polish,Smooth Limiter}>Mode
slider2:input_drive_db=3.5<-12,18,0.1>Input Drive dB
slider3:auto_adapt_pct=50<0,100,1>Auto-Adapt percent
in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

@init
ext_tail_size = -2;

core_last_mode = -1;
core_initial_apply = 1;

agc_lgain = 1;
agc_hgain = 1;
final_threshold_drive_s = 1;


fcs_buf_len = 512;
fcs_buf_l = 0;
fcs_buf_r = 512;
fcs_buf_ol = 1024;
fcs_buf_or = 1536;
fcs_wrpos = 0;

snub_buf_len = 512;
snub_wrpos = 0;
snub_p1_l = 2048;  snub_p1_r = 2560;
snub_p2_l = 3072;  snub_p2_r = 3584;
snub_p3_l = 4096;  snub_p3_r = 4608;
snub_p4_l = 5120;  snub_p4_r = 5632;
snub_p5_l = 6144;  snub_p5_r = 6656;
snub_p6_l = 7168;  snub_p6_r = 7680;


master_buf_len = 4096;
master_buf_l = 10240;
master_buf_r = 14336;
master_wrpos = 0;

master_startup_armed = 1;
master_startup_age = 0;

function db2lin(db)
(
  10^(db/20);
);

function lin2db(x)
(
  20 * log(max(x, 0.0000001)) / log(10);
);

function clamp(x lo hi)
(
  min(max(x, lo), hi);
);

function absmax2(a b)
(
  max(abs(a), abs(b));
);

function onepole_lp(x a) instance(z)
(
  z += a * (x - z);
  z;
);

function onepole_lp2(x a) instance(z1 z2)
(
  z1 += a * (x - z1);
  z2 += a * (z1 - z2);
  z2;
);

function onepole_hp(x a) instance(z) local(y)
(
  z += a * (x - z);
  y = x - z;
  y;
);

function allpass1(x c) instance(x1 y1) local(y)
(
  y = -c*x + x1 + c*y1;
  x1 = x;
  y1 = y;
  y;
);

function ap_coeff(freq) local(t)
(
  freq = clamp(freq, 5, srate * 0.45);
  t = tan($pi * freq / srate);
  (t - 1) / (t + 1);
);

function peak_env(det att rel) instance(e)
(
  det > e ? e = det + att * (e - det) : e = det + rel * (e - det);
  e;
);

function peak_env_set(v) instance(e)
(
  e = v;
  e;
);

function band_limit_gain(det thresh att rel) instance(env gain) local(tg)
(
  gain <= 0 ? gain = 1;
  det > env ? env = det + att * (env - det) : env = det + rel * (env - det);
  env = max(env, 0.000001);
  tg = env > thresh ? thresh / env : 1;
  tg = clamp(tg, 0.10, 1);
  tg < gain ? gain = tg + att * (gain - tg) : gain = tg + rel * (gain - tg);
  gain;
);

function band_limit_gain_pd(det thresh att rel_base rel_slow pd_amt) instance(env gain) local(tg depth rel_now)
(
  gain <= 0 ? gain = 1;

  depth = clamp((env - thresh) / max(thresh * 2.5, 0.000001), 0, 1);
  rel_now = rel_base * (1 - pd_amt * depth) + rel_slow * (pd_amt * depth);
  det > env ? env = det + att * (env - det) : env = det + rel_now * (env - det);

  env = max(env, 0.000001);
  tg = env > thresh ? thresh / env : 1;
  tg = clamp(tg, 0.10, 1);

  depth = clamp((1 - gain) / 0.75, 0, 1);
  rel_now = rel_base * (1 - pd_amt * depth) + rel_slow * (pd_amt * depth);
  tg < gain ? gain = tg + att * (gain - tg) : gain = tg + rel_now * (gain - tg);
  gain;
);

function linked_limiter_gain(det thresh att rel) instance(gain) local(tg)
(
  gain <= 0 ? gain = 1;
  tg = det > thresh ? thresh / max(det, 0.000001) : 1;
  tg = clamp(tg, 0.08, 1);
  tg < gain ? gain = tg + att * (gain - tg) : gain = tg + rel * (gain - tg);
  gain;
);

function band_limit_gain_pd_soft(det thresh att rel_base rel_slow pd_amt ratio knee min_gain) instance(env gain) local(tg depth rel_now over soft)
(
  gain <= 0 ? gain = 1;

  depth = clamp((env - thresh) / max(thresh * 2.5, 0.000001), 0, 1);
  rel_now = rel_base * (1 - pd_amt * depth) + rel_slow * (pd_amt * depth);
  det > env ? env = det + att * (env - det) : env = det + rel_now * (env - det);

  env = max(env, 0.000001);
  over = env / max(thresh, 0.000001);
  over > 1 ? (
    soft = clamp((over - 1) / max((over - 1) + knee, 0.000001), 0, 1);
    tg = over^((1 / max(ratio, 1.01)) - 1);
    tg = 1 - soft * (1 - tg);
  ) : (
    tg = 1;
  );
  tg = clamp(tg, min_gain, 1);

  depth = clamp((1 - gain) / 0.75, 0, 1);
  rel_now = rel_base * (1 - pd_amt * depth) + rel_slow * (pd_amt * depth);
  tg < gain ? gain = tg + att * (gain - tg) : gain = tg + rel_now * (gain - tg);
  gain;
);

function soft_clip_knee(x th knee_mul) local(ax sgn over knee y)
(
  ax = abs(x);
  ax <= th ? (
    x;
  ) : (
    sgn = x < 0 ? -1 : 1;
    over = ax - th;
    knee = max(0.000001, th * knee_mul);
    y = th + knee * (1 - exp(-over / knee));
    sgn * y;
  );
);

function mb_soft_clip(x th amt knee_mul) local(c)
(
  c = soft_clip_knee(x, th, knee_mul);
  x * (1 - amt) + c * amt;
);

function mb_soft_clip_dc(x th amt knee_mul cancel_amt a) instance(dc_z) local(c dist dist_low y)
(
  c = soft_clip_knee(x, th, knee_mul);
  dist = c - x;

  dc_z += a * (dist - dc_z);
  dist_low = dc_z;
  y = c - dist_low * cancel_amt;
  x * (1 - amt) + y * amt;
);

function bass_clip_active(x th amt knee_mul drive res_mix a) instance(z1 z2) local(xd c dist dist_filt clip_mix residue_mix)
(

  drive = max(drive, 1);
  xd = x * drive;
  c = soft_clip_knee(xd, th, knee_mul) / drive;
  dist = c - x;

  z1 += a * (dist - z1);
  z2 += a * (z1 - z2);
  dist_filt = z2;

  clip_mix = amt * (0.50 + 0.50 * amt);
  residue_mix = amt * res_mix * (0.35 + 0.65 * amt);
  x + dist * clip_mix + dist_filt * residue_mix;
);

function pure_peak_round(x th amt drive_mul) local(d lim y)
(

  amt <= 0 ? (
    x;
  ) : (
    th = max(th, 0.000001);
    d = drive_mul / th;
    lim = $pi * 0.5;
    y = sin(clamp(x * d, -lim, lim)) / d;
    x * (1 - amt) + y * amt;
  );
);

function smooth_drive_rounder(x amt) instance(prev_sat) local(sat apply y)
(

  amt = clamp(amt, 0, 1);
  amt <= 0.0000001 ? (
    x;
  ) : (
    sat = sin(clamp(x, -$pi * 0.5, $pi * 0.5));
    apply = clamp(abs(prev_sat + sat) * 0.5 * amt, 0, 1);
    y = x * (1 - apply) + sat * apply;
    prev_sat = sat;
    y;
  );
);

function hard_limit(x ceiling)
(
  min(max(x, -ceiling), ceiling);
);

function reset_phase_state()
(
  ap1_l.x1 = 0; ap1_l.y1 = 0; ap1_r.x1 = 0; ap1_r.y1 = 0;
  ap2_l.x1 = 0; ap2_l.y1 = 0; ap2_r.x1 = 0; ap2_r.y1 = 0;
  ap3_l.x1 = 0; ap3_l.y1 = 0; ap3_r.x1 = 0; ap3_r.y1 = 0;
  ap4_l.x1 = 0; ap4_l.y1 = 0; ap4_r.x1 = 0; ap4_r.y1 = 0;
  ap5_l.x1 = 0; ap5_l.y1 = 0; ap5_r.x1 = 0; ap5_r.y1 = 0;
  ap6_l.x1 = 0; ap6_l.y1 = 0; ap6_r.x1 = 0; ap6_r.y1 = 0;
  ap7_l.x1 = 0; ap7_l.y1 = 0; ap7_r.x1 = 0; ap7_r.y1 = 0;
  ap8_l.x1 = 0; ap8_l.y1 = 0; ap8_r.x1 = 0; ap8_r.y1 = 0;
  ap9_l.x1 = 0; ap9_l.y1 = 0; ap9_r.x1 = 0; ap9_r.y1 = 0;
  ap10_l.x1 = 0; ap10_l.y1 = 0; ap10_r.x1 = 0; ap10_r.y1 = 0;
  ap11_l.x1 = 0; ap11_l.y1 = 0; ap11_r.x1 = 0; ap11_r.y1 = 0;
  ap12_l.x1 = 0; ap12_l.y1 = 0; ap12_r.x1 = 0; ap12_r.y1 = 0;
);

function reset_dynamic_state() local(i)
(

  agc_lgain = 1;
  agc_hgain = 1;
  startup_activity = 0;
  gate_prog_env = 0;
  gate_state = 0;
  gate_closed_memory = 0;
  gate_reopen_env = 0;
  gate_reopen_pulse = 0;
  agc_attack_assist_state = 0;
  agc_surge_catch_state = 0;
  agc_makeup_guard_state = 0;

  agc_low_env.e = 0;
  agc_high_env.e = 0;
  final_full_env.e = 0;
  final_threshold_drive_s = final_threshold_drive_target > 0 ? final_threshold_drive_target : 1;
  preclip.gain = 1;
  final_round_l.prev_sat = 0;
  final_round_r.prev_sat = 0;
  post_agc_round_l.prev_sat = 0;
  post_agc_round_r.prev_sat = 0;
  post_xt2_round_l.prev_sat = 0;
  post_xt2_round_r.prev_sat = 0;

  reset_phase_state();

  lim1.env = 0; lim1.gain = 1;
  lim2.env = 0; lim2.gain = 1;
  lim3.env = 0; lim3.gain = 1;
  lim4.env = 0; lim4.gain = 1;
  lim5.env = 0; lim5.gain = 1;
  lim6.env = 0; lim6.gain = 1;

  adapt_bass_gain = 1;
  adapt_bass_env.e = 0;
  adapt_prog_env.e = 0;
  adapt_bass_lp_l.z1 = 0; adapt_bass_lp_l.z2 = 0; adapt_bass_lp_r.z1 = 0; adapt_bass_lp_r.z2 = 0;

  bassclip_pre_l.z1 = 0; bassclip_pre_l.z2 = 0; bassclip_pre_r.z1 = 0; bassclip_pre_r.z2 = 0;
  bassclip_split_l.z1 = 0; bassclip_split_l.z2 = 0; bassclip_split_r.z1 = 0; bassclip_split_r.z2 = 0;
  bassclip_hpf_l.z = 0; bassclip_hpf_r.z = 0;
  bassclip1_l.z1 = 0; bassclip1_l.z2 = 0; bassclip1_r.z1 = 0; bassclip1_r.z2 = 0;
  bassclip2_l.z1 = 0; bassclip2_l.z2 = 0; bassclip2_r.z1 = 0; bassclip2_r.z2 = 0;

  ub_gate4.e = 0; ub_gate5.e = 0; ub_gate6.e = 0;
  ub_lim6.gain = 1;
  us_prev4_l = 0; us_prev4_r = 0; us_prev24_l = 0; us_prev24_r = 0;
  us_prev5_l = 0; us_prev5_r = 0; us_prev25_l = 0; us_prev25_r = 0;
  us_prev6_l = 0; us_prev6_r = 0; us_prev26_l = 0; us_prev26_r = 0;

  fcs_wrpos = 0;
  snub_wrpos = 0;
  master_wrpos = 0;
  master_startup_armed = 1;
  master_startup_age = 0;
  master_catch_gain = 1;
  master_raw_env.e = 0;
  master_amp_env.e = 0;
  master_catch_env.e = 0;

  i = 0;
  loop(fcs_buf_len,
    fcs_buf_l[i] = 0; fcs_buf_r[i] = 0; fcs_buf_ol[i] = 0; fcs_buf_or[i] = 0;
    i += 1;
  );
  i = 0;
  loop(snub_buf_len,
    snub_p1_l[i] = 0; snub_p1_r[i] = 0; snub_p2_l[i] = 0; snub_p2_r[i] = 0;
    snub_p3_l[i] = 0; snub_p3_r[i] = 0; snub_p4_l[i] = 0; snub_p4_r[i] = 0;
    snub_p5_l[i] = 0; snub_p5_r[i] = 0; snub_p6_l[i] = 0; snub_p6_r[i] = 0;
    i += 1;
  );
  i = 0;
  loop(master_buf_len,
    master_buf_l[i] = 0; master_buf_r[i] = 0;
    i += 1;
  );
);

function biquad_lp_set(freq q) instance(a0 a1 a2 b1 b2) local(w0 cw sw alpha norm)
(
  freq = clamp(freq, 20, srate * 0.45);
  w0 = 2*$pi*freq/srate;
  cw = cos(w0);
  sw = sin(w0);
  alpha = sw/(2*q);
  norm = 1/(1 + alpha);
  a0 = ((1 - cw) * 0.5) * norm;
  a1 = (1 - cw) * norm;
  a2 = a0;
  b1 = (-2 * cw) * norm;
  b2 = (1 - alpha) * norm;
);

function biquad_peak_set(freq q gain_db) instance(a0 a1 a2 b1 b2) local(A w0 cw sw alpha b0 bb1 bb2 aa0 aa1 aa2 norm)
(
  freq = clamp(freq, 20, srate * 0.45);
  A = 10^(gain_db/40);
  w0 = 2*$pi*freq/srate;
  cw = cos(w0);
  sw = sin(w0);
  alpha = sw/(2*q);
  b0 = 1 + alpha*A;
  bb1 = -2*cw;
  bb2 = 1 - alpha*A;
  aa0 = 1 + alpha/A;
  aa1 = -2*cw;
  aa2 = 1 - alpha/A;
  norm = 1/aa0;
  a0 = b0*norm;
  a1 = bb1*norm;
  a2 = bb2*norm;
  b1 = aa1*norm;
  b2 = aa2*norm;
);

function biquad_run(x) instance(a0 a1 a2 b1 b2 x1 x2 y1 y2) local(y)
(
  y = a0*x + a1*x1 + a2*x2 - b1*y1 - b2*y2;
  x2 = x1;
  x1 = x;
  y2 = y1;
  y1 = y;
  y;
);


@slider

core_mode = floor(clamp(core_mode, 0, 2) + 0.5);
auto_adapt_pct = clamp(auto_adapt_pct, 0, 100);
input_drive_db = clamp(input_drive_db, -12, 18);

core_default_input_db = core_mode == 0 ? 3.5 : core_mode == 1 ? 4.5 : 0;
core_mode_changed = core_initial_apply || core_mode != core_last_mode;

core_mode_changed ? (
  input_drive_db = core_default_input_db;
  sliderchange(2);
  core_state_reset = 1;
);

core_mode == 0 ? (
  input_trim_db = 3.5;
  phase_rotate_pct = 3;
  subsonic_hpf = 1;
  agc_amount_pct = 65;
  agc_drive_db = 0.5;
  release_time = 7;
  pd_release_pct = 70;
  gate_threshold_db = -30;
  gate_reopen_speed_ms = 40;
  gate_reopen_strength_pct = 65;
  first_hit_catch_pct = 35;
  post_agc_smooth_drive_pct = 25;
  bass_coupling_pct = 70;
  bass_eq_db = 2;
  bass_sc_relief_pct = 35;
  low_bass_floor_pct = 15;
  low_coherence_pct = 65;
  low_release_stab_pct = 70;
  transition_fill_pct = 18;
  adaptive_bass_coupling_pct = 12;
  bass_clip_pct = 8;
  bass_clip_density_pct = 0;
  density_db = 1;
  xt2_amount_pct = 100;
  presence_db = 2;
  brilliance_db = 2;
  adaptive_top_coupling_pct = 35;
  crossover_model = 2;
  mb_clip_pct = 0;
  clip_drive_db = 0;
  recomb_control_pct = 0;
  dc_cancel_pct = 65;
  upper_snubber_pct = 78;
  snubber_lookahead_ms = 1.5;
  post_xt2_smooth_drive_pct = 12;
  stereo_mode = 0;
  stereo_width_pct = 100;
  pre_final_drive_db = 0;
  clipper_style = 0;
  pre_limiter_pct = 100;
  clip_restraint_pct = 100;
  overshoot_pct = 50;
  lookahead_ms = 0.36;
  final_threshold_db = 0;
  final_threshold_makeup_pct = 0;
  clip_ceiling_db = -1;
  top_filter_mode = 2;
  output_trim_db = 0;
  smooth_drive_rounder_pct = 0;
) : core_mode == 1 ? (
  input_trim_db = 4.5;
  phase_rotate_pct = 4;
  agc_amount_pct = 56;
  agc_drive_db = 0.2;
  bass_coupling_pct = 60;
  release_time = 6.1;
  gate_threshold_db = -30;
  gate_reopen_speed_ms = 50;
  gate_reopen_strength_pct = 55;
  density_db = 4.7;
  xt2_amount_pct = 84;
  bass_eq_db = 3.6;
  presence_db = 2.3;
  brilliance_db = 3.2;
  clip_drive_db = -0.8;
  clipper_style = 2;
  pre_limiter_pct = 44;
  clip_restraint_pct = 26;
  clip_ceiling_db = -1.2;
  final_threshold_db = 0;
  final_threshold_makeup_pct = 0;
  stereo_mode = 0;
  stereo_width_pct = 100;
  top_filter_mode = 1;
  subsonic_hpf = 0;
  output_trim_db = 0;
  mb_clip_pct = 18;
  dc_cancel_pct = 64;
  overshoot_pct = 72;
  recomb_control_pct = 68;
  lookahead_ms = 0.54;
  crossover_model = 2;
  pd_release_pct = 78;
  bass_sc_relief_pct = 76;
  low_coherence_pct = 82;
  low_release_stab_pct = 74;
  transition_fill_pct = 12;
  low_bass_floor_pct = 42;
  adaptive_bass_coupling_pct = 65;
  adaptive_top_coupling_pct = 25;
  bass_clip_pct = 32;
  bass_clip_density_pct = 6;
  upper_snubber_pct = 42;
  snubber_lookahead_ms = 0.73;
  first_hit_catch_pct = 42;
  post_agc_smooth_drive_pct = 14;
  post_xt2_smooth_drive_pct = 20;
  pre_final_drive_db = 0;
) : (
  input_trim_db = 0;
  phase_rotate_pct = 0;
  subsonic_hpf = 0;
  agc_amount_pct = 0;
  agc_drive_db = 0;
  release_time = 6.5;
  pd_release_pct = 0;
  gate_threshold_db = -70;
  gate_reopen_speed_ms = 50;
  gate_reopen_strength_pct = 0;
  first_hit_catch_pct = 0;
  post_agc_smooth_drive_pct = 0;
  bass_coupling_pct = 0;
  bass_eq_db = 0;
  bass_sc_relief_pct = 0;
  low_bass_floor_pct = 0;
  low_coherence_pct = 0;
  low_release_stab_pct = 0;
  transition_fill_pct = 0;
  adaptive_bass_coupling_pct = 0;
  bass_clip_pct = 25;
  bass_clip_density_pct = 0;
  density_db = -0.4;
  xt2_amount_pct = 10;
  presence_db = 0;
  brilliance_db = 0;
  adaptive_top_coupling_pct = 0;
  crossover_model = 2;
  mb_clip_pct = 20;
  clip_drive_db = 0;
  recomb_control_pct = 6;
  dc_cancel_pct = 0;
  upper_snubber_pct = 100;
  snubber_lookahead_ms = 1.5;
  post_xt2_smooth_drive_pct = 10;
  stereo_mode = 0;
  stereo_width_pct = 100;
  pre_final_drive_db = -2;
  clipper_style = 0;
  pre_limiter_pct = 100;
  clip_restraint_pct = 60;
  overshoot_pct = 100;
  lookahead_ms = 0.73;
